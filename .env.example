# Copy to .env and fill in. Never commit .env.
#   cp .env.example .env

# ── Environment ──────────────────────────────────────────────
ENV=dev                        # dev | test | prod
LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR

# ── Database (Postgres 16) ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres     # change in production!
POSTGRES_DB=app

# ── LLM — Anthropic Claude ──────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-sonnet-4-6    # any Claude model with vision support

# ── Linear (ticket management) ───────────────────────────────
# Create at https://linear.app/settings/api
LINEAR_API_KEY=lin_api_REPLACE_ME
LINEAR_TEAM_KEY=TEA              # short key for your Linear team (e.g. TEA → TEA-1, TEA-2)
LINEAR_WEBHOOK_SECRET=           # HMAC secret for Linear webhook signature verification

# ── GitHub ───────────────────────────────────────────────────
# PAT with repo scope: https://github.com/settings/tokens
GITHUB_API_TOKEN=github_pat_REPLACE_ME
GITHUB_REPO=owner/repo          # e.g. your-org/your-repo
GITHUB_BASE_BRANCH=main         # base branch for auto-created PRs
GITHUB_WEBHOOK_SECRET=           # HMAC secret for GitHub webhook signature verification

# ── Email (Resend) ───────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=onboarding@resend.dev # sender address (must be verified in Resend)

# ── Observability (Arize Phoenix) ────────────────────────────
# Phoenix runs as a docker compose service — defaults work out of the box.
# Only override if you run Phoenix externally.
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
# PHOENIX_PROJECT_NAME=sre-agents

# ── Docker image tag (prod compose only) ─────────────────────
TAG=dev
